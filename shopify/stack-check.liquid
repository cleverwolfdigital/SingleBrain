  }
  renderTip();

  /* Consent gate */
  var gate=$id('gate'), gateGo=$id('gate-go'), agree=$id('agree'), app=$id('app');
  function storeGet(k){ try{ return window.localStorage.getItem(k); }catch(e){ return null; } }
