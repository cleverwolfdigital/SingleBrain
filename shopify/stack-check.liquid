  var stack = [];

  var TIPS = [
    {title:"Caffeine works better with L-theanine", body:"On their own, caffeine sharpens speed and L-theanine does little; together they improve accuracy on attention-switching tasks and steady alertness without the jittery edge. A theanine:caffeine ratio around 2:1 is the commonly studied pairing.", source:"Haskell et al., 2008, Biological Psychology; Owen et al., 2008, Nutritional Neuroscience"},
    {title:"Bacopa is a long game, not a same-day boost", body:"Pooled trial data show bacopa's benefits to memory recall and speed of attention emerge only after roughly 12 weeks of daily use — so judge it over months, not the first dose, and take it with food to ease digestion.", source:"Kongkeaw et al., 2014, Journal of Ethnopharmacology"},
    {title:"Creatine isn't just for muscles", body:"5 g of creatine daily for six weeks improved working memory and reasoning in a placebo-controlled trial, with the biggest gains under mental fatigue and sleep deprivation — your brain runs on the same energy currency your muscles do.", source:"Rae et al., 2003, Proceedings of the Royal Society B"},
    {title:"Lion's Mane needs to stay in the routine", body:"In adults with mild cognitive complaints, 16 weeks of Lion's Mane improved cognitive scores — but the gains faded within weeks of stopping. It appears to work through nerve-growth-factor pathways, and only with consistent, ongoing use.", source:"Mori et al., 2009, Phytotherapy Research"},
    {title:"Stacking choline sources is the usual culprit behind 'nootropic headache'", body:"Citicoline, Alpha-GPC, and choline bitartrate all raise acetylcholine. Combine several — especially alongside an acetylcholinesterase inhibitor like Huperzine A — and headache or nausea becomes likely. If it happens, cut one source before adding anything new.", source:"Mechanism from cholinergic pharmacology reviews"},
    {title:"Huperzine A quietly carries into tomorrow", body:"Huperzine A slows the breakdown of acetylcholine and has a long duration of action, so daily dosing lets its effect accumulate. Cycling it (with regular days off) is the common way to avoid a creeping cholinergic overload.", source:"Reviews of huperzine pharmacokinetics"},
    {title:"Time your caffeine by its half-life", body:"Caffeine's half-life runs roughly 5–6 hours in most adults, meaning an afternoon dose can still be circulating at bedtime. Front-loading stimulants before early afternoon protects the sleep that your cognition depends on most.", source:"Caffeine pharmacokinetics literature"},
    {title:"Omega-3 DHA is structural, not stimulating", body:"DHA is a building block of neuronal membranes rather than a same-day booster. Its value shows up over the long term for brain maintenance, and it works synergistically with choline and uridine in membrane synthesis.", source:"Omega-3 and neuronal membrane research"},
    {title:"Rhodiola is for fatigue, and belongs in the morning", body:"Rhodiola is an adaptogen studied for reducing mental fatigue and improving performance under stress. Because it can be mildly activating, taking it earlier in the day avoids interfering with sleep.", source:"Randomized trials on Rhodiola rosea and fatigue"},
    {title:"No stack outperforms sleep", body:"Every same-day nootropic effect is smaller than the cognitive cost of a poor night's sleep. Supplements are a layer on top of sleep, exercise, and hydration — most disappointing 'stacks' are really a sleep-debt problem in disguise.", source:"Sleep and cognition research consensus"},
    {title:"Add one compound at a time", body:"Introduce a single new ingredient and give it a week or two before adding another. It's the only way to actually attribute a benefit — or a side effect — to the right compound instead of guessing across a crowded stack.", source:"Standard nootropic self-experimentation practice"},
    {title:"Phosphatidylserine has an evening role", body:"Phosphatidylserine supports memory and can blunt the cortisol response to stress, which is part of why many people place it later in the day rather than stacking it with their morning stimulants.", source:"Phosphatidylserine and cortisol studies"},
    {title:"Watch total caffeine across every source", body:"Guarana, theobromine-heavy blends, pre-workouts, coffee, and 'focus' drinks add up fast. Around 400 mg/day is a common ceiling for healthy adults; past it, the returns turn into jitters and disrupted sleep.", source:"Dietary caffeine safety reviews"},
    {title:"Ginkgo and blood thinners don't mix well", body:"Ginkgo can affect blood clotting, so it warrants caution alongside anticoagulants and before surgery. It's a reminder that 'natural' doesn't mean 'no interactions' — the same applies to ginseng and high-dose fish oil.", source:"Herb–drug interaction literature"},
    {title:"Tyrosine helps most when you're depleted", body:"N-acetyl-L-tyrosine is a dopamine precursor whose cognitive benefits show up mainly under stress, cold, or sleep deprivation — situations that drain catecholamines — rather than in already well-rested conditions.", source:"Tyrosine and stress-cognition trials"}
  ];
  function renderTip(){
    var now=new Date();
    var start=new Date(now.getFullYear(),0,0);
    var day=Math.floor((now-start)/86400000);
    var tip=TIPS[day % TIPS.length];
    $id('tip-date').textContent=now.toLocaleDateString(undefined,{month:'short',day:'numeric',year:'numeric'});
    $id('tip-title').textContent=tip.title;
    $id('tip-body').textContent=tip.body;
