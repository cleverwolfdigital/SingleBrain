{%- comment -%}
  Stack Check — Level Up Self cognitive-stack utility.
  Self-contained Shopify section. Runs its own JS natively (no iframe).
  All CSS is scoped under .sc-app and all DOM lookups are scoped to #sc-app-root
  so nothing collides with or leaks into the surrounding theme.
  Products are wired to real Level Up Self Shopify handles.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/tesseract.js/5.1.1/tesseract.min.js"></script>

<style>
.sc-app{--paper:#FFFFFF;--wash:#F5F6F7;--panel:#FFFFFF;--ink:#1E252F;--ink-soft:#6B7280;--red:#E5353D;--red-deep:#C42630;--amber:#E0912B;--green:#2E9E6B;--line:#E7E9EC;--line-soft:#F0F2F3;--shadow:0 1px 2px rgba(30,37,47,.05),0 10px 26px rgba(30,37,47,.06);
  background:var(--paper);color:var(--ink);font-family:'Inter',system-ui,-apple-system,sans-serif;line-height:1.5;-webkit-font-smoothing:antialiased;padding:22px 16px 48px}
.sc-app *,.sc-app *::before,.sc-app *::after{box-sizing:border-box}
.sc-app img{display:block;max-width:100%}
.sc-app ::selection{background:#DA291C;color:#15102E}
.sc-app .hidden{display:none}
.sc-app .wrap{max-width:760px;margin:0 auto}
.sc-app .brandbar{display:flex;align-items:center;gap:14px;margin-bottom:22px;padding-bottom:18px;border-bottom:2px solid var(--ink)}
.sc-app .brandlogo{font-family:'Montserrat',sans-serif;font-weight:800;font-size:22px;letter-spacing:-.01em;text-transform:uppercase;color:var(--ink)}
.sc-app .brandlogo b{color:var(--red)}
.sc-app .brandbar .tagline{font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-soft);margin-left:auto;text-align:right;line-height:1.35}
.sc-app .brandbar .tagline b{color:var(--red)}
.sc-app .eyebrow{font-family:'Montserrat',sans-serif;font-weight:700;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin:0 0 8px}
.sc-app h1{font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(27px,6vw,40px);line-height:1;letter-spacing:-.01em;text-transform:uppercase;margin:0 0 12px}
.sc-app h1 .accent{color:var(--red)}
.sc-app .lede{color:var(--ink-soft);font-size:15px;max-width:58ch;margin:0}
.sc-app .tipcard{margin-top:22px;background:var(--panel);border:1px solid var(--line);border-left:5px solid var(--red);border-radius:14px;padding:18px 20px;box-shadow:var(--shadow)}
.sc-app .tip-top{display:flex;align-items:baseline;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px}
.sc-app .tip-eyebrow{font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--red)}
.sc-app .tip-date{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-soft)}
.sc-app .tip-title{font-family:'Montserrat',sans-serif;font-weight:700;font-size:17px;line-height:1.2;margin-bottom:6px}
.sc-app .tip-body{font-size:14px;color:var(--ink);line-height:1.55}
.sc-app .tip-src{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-soft);margin-top:10px;padding-top:9px;border-top:1px solid var(--line-soft)}
.sc-app .tip-src b{color:var(--ink);font-weight:600}
.sc-app .tabs{display:flex;gap:4px;background:var(--wash);padding:4px;border-radius:12px;margin:24px 0 18px;width:fit-content;max-width:100%}
.sc-app .tab{font-family:'Montserrat',sans-serif;font-weight:700;font-size:13px;letter-spacing:.02em;text-transform:uppercase;border:0;background:transparent;color:var(--ink-soft);cursor:pointer;padding:10px 18px;border-radius:9px;transition:all .15s;white-space:nowrap}
.sc-app .tab[aria-selected="true"]{background:var(--red);color:#fff;box-shadow:var(--shadow)}
.sc-app .panel{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:22px;box-shadow:var(--shadow)}
.sc-app .panel + .panel{margin-top:16px}
.sc-app .panel-head{font-family:'Montserrat',sans-serif;font-weight:700;font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink);margin:0 0 14px;display:flex;align-items:center;gap:8px}
.sc-app .panel-head .beta{font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.08em;background:var(--wash);color:var(--ink-soft);border:1px solid var(--line);padding:2px 6px;border-radius:20px}
.sc-app .drop{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;text-align:center;border:1.5px dashed var(--line);border-radius:13px;padding:22px 16px;background:var(--wash);cursor:pointer;transition:border-color .15s;position:relative}
.sc-app .drop:hover,.sc-app .drop:focus-within{border-color:var(--red)}
.sc-app .drop .di{font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px}
.sc-app .drop .ds{font-size:12.5px;color:var(--ink-soft);max-width:40ch}
.sc-app .drop input{position:absolute;width:1px;height:1px;opacity:0;pointer-events:none}
.sc-app .photo-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:2px}
.sc-app .btn-line{font-family:'Montserrat',sans-serif;font-weight:700;font-size:12.5px;text-transform:uppercase;letter-spacing:.03em;border:1.5px solid var(--ink);background:var(--ink);color:#fff;border-radius:9px;padding:11px 16px;cursor:pointer;transition:background .15s}
.sc-app .btn-line:hover{background:var(--red);border-color:var(--red)}
.sc-app .btn-ghost{background:transparent;color:var(--ink);border-color:var(--line)}
.sc-app .btn-ghost:hover{background:var(--wash);border-color:var(--ink);color:var(--ink)}
.sc-app .preview{margin-top:14px;display:none;gap:14px;align-items:flex-start}
.sc-app .preview.show{display:flex}
.sc-app .preview img{width:84px;height:84px;object-fit:cover;border-radius:10px;border:1px solid var(--line);flex-shrink:0}
.sc-app .preview .pstat{font-size:13px;color:var(--ink-soft);min-width:0}
.sc-app .progress{height:6px;border-radius:4px;background:var(--line-soft);overflow:hidden;margin-top:8px}
.sc-app .progress .pf{height:100%;width:0;background:var(--red);transition:width .25s}
.sc-app .detected{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
.sc-app .dchip{font-family:'Inter',sans-serif;font-size:13px;font-weight:600;border:1.5px solid var(--green);background:#E9F6EF;color:#1c6b48;border-radius:20px;padding:7px 13px;cursor:pointer;display:inline-flex;align-items:center;gap:6px}
.sc-app .dchip:hover{background:var(--green);color:#fff}
.sc-app .dchip .plus{font-weight:700}
.sc-app .divider{display:flex;align-items:center;gap:12px;margin:18px 0;color:var(--ink-soft);font-size:12px;font-family:'IBM Plex Mono',monospace;letter-spacing:.06em}
.sc-app .divider::before,.sc-app .divider::after{content:"";height:1px;background:var(--line);flex:1}
.sc-app .search{position:relative}
.sc-app .search input{width:100%;font-family:'Inter',sans-serif;font-size:16px;color:var(--ink);padding:13px 15px;border:1.5px solid var(--line);border-radius:11px;background:var(--wash);transition:border-color .15s}
.sc-app .search input:focus{outline:0;border-color:var(--red);background:var(--panel)}
.sc-app .search input::placeholder{color:#9AA1AA}
.sc-app .results{position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:20;background:var(--panel);border:1px solid var(--line);border-radius:12px;box-shadow:0 14px 34px rgba(30,37,47,.16);overflow:hidden;max-height:280px;overflow-y:auto}
.sc-app .results button{display:flex;width:100%;text-align:left;border:0;background:transparent;cursor:pointer;padding:12px 15px;gap:10px;align-items:baseline;border-bottom:1px solid var(--line-soft)}
.sc-app .results button:last-child{border-bottom:0}
.sc-app .results button:hover,.sc-app .results button.active{background:var(--wash)}
.sc-app .results .r-name{font-weight:600;font-size:14px}
.sc-app .results .r-cat{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-soft);margin-left:auto;white-space:nowrap}
.sc-app .hint{font-size:12.5px;color:var(--ink-soft);margin:10px 2px 0}
.sc-app .added{margin-top:18px;display:flex;flex-direction:column;gap:8px}
.sc-app .row{display:flex;align-items:center;gap:12px;padding:12px 14px;border:1px solid var(--line);border-radius:11px;background:var(--wash)}
.sc-app .row .r-main{min-width:0;flex:1}
.sc-app .row .r-title{font-weight:600;font-size:14.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sc-app .row .r-sub{font-size:12px;color:var(--ink-soft);margin-top:1px}
.sc-app .dose{display:flex;align-items:center;gap:5px}
.sc-app .dose input{width:66px;font-family:'IBM Plex Mono',monospace;font-size:14px;text-align:right;padding:8px;border:1.5px solid var(--line);border-radius:8px;background:var(--panel);color:var(--ink)}
.sc-app .dose input:focus{outline:0;border-color:var(--red)}
.sc-app .dose .unit{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--ink-soft);width:30px}
.sc-app .rm{border:0;background:transparent;color:#B6BCC4;cursor:pointer;font-size:22px;line-height:1;padding:4px 6px;border-radius:6px;min-height:36px}
.sc-app .rm:hover{color:var(--red);background:#FBE9EA}
.sc-app .empty{color:var(--ink-soft);font-size:14px;padding:22px 4px;text-align:center;border:1px dashed var(--line);border-radius:11px}
.sc-app .meters{display:grid;gap:16px;margin-top:2px}
.sc-app .meter .m-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:7px;gap:10px}
.sc-app .meter .m-name{font-family:'Montserrat',sans-serif;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.03em}
.sc-app .meter .m-val{font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:500;text-align:right;white-space:nowrap}
.sc-app .track{height:9px;border-radius:6px;background:var(--line-soft);overflow:hidden}
.sc-app .fill{height:100%;border-radius:6px;transition:width .35s ease,background .25s}
.sc-app .ticks{display:flex;justify-content:space-between;margin-top:5px}
.sc-app .ticks span{font-family:'IBM Plex Mono',monospace;font-size:10px;color:#9AA1AA}
.sc-app .status-clear{color:var(--green)}.sc-app .status-caution{color:var(--amber)}.sc-app .status-high{color:var(--red)}
.sc-app .flags{margin-top:20px;display:flex;flex-direction:column;gap:9px}
.sc-app .flag{display:flex;gap:11px;padding:12px 14px;border-radius:11px;font-size:13.5px;align-items:flex-start}
.sc-app .flag.warn{background:#FCF3E4;border:1px solid #F2DFB6}
.sc-app .flag.danger{background:#FCEBEC;border:1px solid #F5CDCF}
.sc-app .flag.ok{background:#E9F6EF;border:1px solid #CBE9DA}
.sc-app .flag .ico{font-family:'IBM Plex Mono',monospace;font-weight:600;flex-shrink:0}
.sc-app .flag.warn .ico{color:var(--amber)}.sc-app .flag.danger .ico{color:var(--red)}.sc-app .flag.ok .ico{color:var(--green)}
.sc-app .flag b{font-weight:600}
.sc-app .prods{display:flex;flex-direction:column;gap:10px}
.sc-app .prod{display:flex;gap:13px;align-items:center;padding:13px 14px;border:1px solid var(--line);border-radius:12px;background:var(--wash)}
.sc-app .prod .p-body{flex:1;min-width:0}
.sc-app .prod .p-name{font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px}
.sc-app .prod .p-why{font-size:12.5px;color:var(--ink-soft);margin-top:2px}
.sc-app .prod a.shop{font-family:'Montserrat',sans-serif;font-weight:700;font-size:11.5px;text-transform:uppercase;letter-spacing:.04em;text-decoration:none;color:#fff;background:var(--red);padding:10px 15px;border-radius:9px;white-space:nowrap;transition:background .15s;min-height:40px;display:inline-flex;align-items:center}
.sc-app .prod a.shop:hover{background:var(--red-deep)}
.sc-app .field{margin-bottom:20px}
.sc-app .field-label{font-family:'Montserrat',sans-serif;font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:.04em;color:var(--ink);margin-bottom:10px;display:block}
.sc-app .chips{display:flex;flex-wrap:wrap;gap:8px}
.sc-app .chip{font-family:'Inter',sans-serif;font-size:14px;font-weight:500;cursor:pointer;padding:10px 15px;border-radius:20px;border:1.5px solid var(--line);background:var(--wash);color:var(--ink-soft);transition:all .15s;min-height:42px}
.sc-app .chip[aria-pressed="true"]{border-color:var(--red);background:var(--red);color:#fff}
.sc-app .go{font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;letter-spacing:.03em;text-transform:uppercase;cursor:pointer;width:100%;padding:16px;border-radius:12px;border:0;background:var(--ink);color:#fff;transition:background .15s;margin-top:4px;min-height:52px}
.sc-app .go:hover{background:var(--red)}
.sc-app .block{margin-top:20px}.sc-app .block:first-child{margin-top:0}
.sc-app .block-h{display:flex;align-items:center;gap:10px;margin-bottom:11px;flex-wrap:wrap}
.sc-app .block-h .lbl{font-family:'Montserrat',sans-serif;font-weight:700;font-size:15px;text-transform:uppercase;letter-spacing:.02em}
.sc-app .block-h .tag{font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);padding:3px 8px;border:1px solid var(--line);border-radius:20px}
.sc-app .item{display:flex;gap:12px;padding:11px 0;border-bottom:1px solid var(--line-soft)}
.sc-app .item:last-child{border-bottom:0}
.sc-app .item .idose{font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--red-deep);font-weight:600;flex-shrink:0;width:92px}
.sc-app .item .iname{font-weight:600;font-size:14px}
.sc-app .item .inote{font-size:12.5px;color:var(--ink-soft);margin-top:2px}
.sc-app .cycle{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--amber);text-transform:uppercase;letter-spacing:.06em;margin-left:6px}
.sc-app .disclaimer{margin-top:22px;font-size:12px;color:var(--ink-soft);line-height:1.55;border-top:1px solid var(--line);padding-top:16px}
.sc-app .disclaimer b{color:var(--ink);font-weight:600}
.sc-app .disclaimer a{color:var(--red);cursor:pointer;text-decoration:underline}
.sc-app .foundation{margin-top:14px;background:var(--wash);border-radius:11px;padding:13px 15px;font-size:12.5px;color:var(--ink-soft)}
.sc-app .foundation b{color:var(--ink)}
.sc-app .brandfoot{margin-top:16px;text-align:center;font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-soft)}
.sc-app .brandfoot b{color:var(--red)}
.sc-app .gate{position:fixed;inset:0;z-index:100;background:rgba(23,33,28,.62);backdrop-filter:blur(3px);display:flex;align-items:center;justify-content:center;padding:18px;overflow-y:auto}
.sc-app .gate-card{background:var(--panel);border-radius:18px;max-width:520px;width:100%;box-shadow:0 24px 60px rgba(0,0,0,.3);padding:26px 24px;margin:auto}
.sc-app .gate-card .g-eyebrow{font-family:'Montserrat',sans-serif;font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin:0 0 8px}
.sc-app .gate-card h2{font-family:'Montserrat',sans-serif;font-weight:800;font-size:22px;text-transform:uppercase;letter-spacing:-.01em;margin:0 0 14px}
.sc-app .terms{max-height:38vh;overflow-y:auto;border:1px solid var(--line);border-radius:11px;padding:15px;background:var(--wash);font-size:12.5px;line-height:1.6;color:var(--ink-soft)}
.sc-app .terms b{color:var(--ink)}.sc-app .terms p{margin:0 0 10px}.sc-app .terms p:last-child{margin:0}
.sc-app .accept{display:flex;gap:11px;align-items:flex-start;margin:16px 0 4px;cursor:pointer}
.sc-app .accept input{width:22px;height:22px;flex-shrink:0;margin-top:1px;accent-color:var(--red);cursor:pointer}
.sc-app .accept span{font-size:13px;color:var(--ink)}
.sc-app .gate-go{font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;letter-spacing:.03em;text-transform:uppercase;width:100%;padding:15px;border-radius:12px;border:0;background:var(--ink);color:#fff;cursor:pointer;margin-top:14px;transition:background .15s;min-height:52px}
.sc-app .gate-go:hover:not(:disabled){background:var(--red)}
.sc-app .gate-go:disabled{background:#C4C9CF;cursor:not-allowed}
body.sc-locked{overflow:hidden}
@media (max-width:520px){
  .sc-app{padding:16px 12px 40px}
  .sc-app .panel{padding:18px 15px;border-radius:14px}
  .sc-app .brandbar .tagline{display:none}
  .sc-app .item .idose{width:76px;font-size:12px}
  .sc-app .dose input{width:58px}
  .sc-app .prod{flex-wrap:wrap}
  .sc-app .prod a.shop{width:100%;justify-content:center}
  .sc-app .tabs{width:100%}.sc-app .tab{flex:1;text-align:center;padding:11px 8px}
  .sc-app .terms{max-height:34vh}
  .sc-app h1{font-size:30px}
}
</style>

<div class="sc-app" id="sc-app-root">

  <!-- CONSENT GATE -->
  <div class="gate" id="gate" role="dialog" aria-modal="true" aria-labelledby="gate-title">
    <div class="gate-card">
      <p class="g-eyebrow">Please read before using</p>
      <h2 id="gate-title">Terms &amp; Medical Disclaimer</h2>
      <div class="terms" tabindex="0">
        <p><b>Educational information only — not medical advice.</b> Stack Check is an informational and organizational tool provided by Level Up Self. It does not provide medical, diagnostic, or treatment advice, and it is not a substitute for consultation with a qualified healthcare professional.</p>
        <p><b>Not evaluated by the FDA.</b> Statements and information within this tool have not been evaluated by the Food and Drug Administration. Nothing here is intended to diagnose, treat, cure, or prevent any disease or health condition.</p>
        <p><b>Consult a professional first.</b> Always speak with your physician or pharmacist before starting, stopping, or combining any supplements — especially if you are pregnant or nursing, under 18, have a medical condition, or take prescription medication (including SSRIs/SNRIs, blood thinners, blood-pressure or stimulant medications).</p>
        <p><b>General information, not personalized guidance.</b> Dosage ranges, interaction flags, and thresholds shown here are general and may not reflect your individual physiology, health status, or the exact formulation of the products you use. Ingredient detection from photos is approximate and may be incomplete or inaccurate; you are responsible for verifying every ingredient and dose against the actual product label.</p>
        <p><b>Assumption of risk.</b> Your use of this tool and any decisions you make based on it are entirely at your own risk and discretion. Results vary between individuals and are not guaranteed.</p>
        <p><b>Limitation of liability.</b> To the fullest extent permitted by law, Level Up Self and its owners, employees, and affiliates disclaim all liability for any loss, injury, or damage arising from use of, or reliance on, this tool. If you do not agree, do not use this tool.</p>
      </div>
      <label class="accept">
        <input type="checkbox" id="agree" />
        <span>I have read and understand the above. I agree to the Terms &amp; Medical Disclaimer, and I choose to use this tool at my own discretion and risk.</span>
      </label>
      <button class="gate-go" id="gate-go" disabled>Agree &amp; continue</button>
    </div>
  </div>

  <div class="wrap" id="app" aria-hidden="true">
    <div class="brandbar">
      <span class="brandlogo">LEVEL UP <b>SELF</b></span>
      <div class="tagline">Cognitive stack utility<br><b>Level up your brain</b></div>
    </div>

    <header>
      <p class="eyebrow">Free tool</p>
      <h1>Stack <span class="accent">Check</span></h1>
      <p class="lede">Snap or upload a supplement label, or type in what you take, to see where ingredients overlap and whether the combined load crosses common caution thresholds — then build a regimen from your goals.</p>
    </header>

    <div class="tipcard">
      <div class="tip-top">
        <span class="tip-eyebrow">🧠 Nootropic tip of the day</span>
        <span class="tip-date" id="tip-date"></span>
      </div>
      <div class="tip-title" id="tip-title"></div>
      <div class="tip-body" id="tip-body"></div>
      <div class="tip-src" id="tip-src"></div>
    </div>

    <div class="tabs" role="tablist">
      <button class="tab" role="tab" id="tab-check" aria-selected="true" aria-controls="view-check">Check a stack</button>
      <button class="tab" role="tab" id="tab-build" aria-selected="false" aria-controls="view-build">Build a regimen</button>
    </div>

    <!-- CHECK VIEW -->
    <section id="view-check" role="tabpanel" aria-labelledby="tab-check">
      <div class="panel">
        <p class="panel-head">Search &amp; add what you take</p>
        <div class="search">
          <input type="text" id="search" autocomplete="off" placeholder="🔍 Search a compound — e.g. citicoline, caffeine, bacopa…" aria-label="Search compounds" />
          <div class="results hidden" id="results"></div>
        </div>
        <p class="hint">List the ingredients from each product separately. If two products both contain a choline donor, add both — that's exactly what this catches.</p>

        <div class="divider">or snap a label <span class="beta">BETA</span></div>

        <label class="drop" for="photo" id="drop">
          <span class="di">📷 Snap or upload a supplement label</span>
          <span class="ds">We'll read the ingredients and detect known compounds automatically. Add anything we miss above.</span>
          <span class="photo-actions">
            <span class="btn-line" id="take">Use camera</span>
            <span class="btn-line btn-ghost" id="pick">Choose photo</span>
          </span>
          <input type="file" id="photo" accept="image/*" capture="environment" />
        </label>
        <div class="preview" id="preview">
          <img id="pimg" alt="Uploaded label" />
