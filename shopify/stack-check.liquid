  if(storeGet('lus_terms_v1')==='1'){ openApp(); } else { document.body.classList.add('sc-locked'); }

  /* Photo OCR */
  var photo=$id('photo'), preview=$id('preview'), pimg=$id('pimg'), pstat=$id('ptext'), pf=$id('pf'), detectedEl=$id('detected');
  $id('take').addEventListener('click',function(e){ e.preventDefault(); photo.setAttribute('capture','environment'); photo.click(); });
  $id('pick').addEventListener('click',function(e){ e.preventDefault(); photo.removeAttribute('capture'); photo.click(); });

  photo.addEventListener('change',function(){
    var file=photo.files&&photo.files[0]; if(!file) return;
    var url=URL.createObjectURL(file);
    pimg.src=url; preview.classList.add('show'); detectedEl.innerHTML=''; pf.style.width='0%';
    if(typeof Tesseract==='undefined'){ pstat.textContent="Automatic reading isn't available right now — add your ingredients manually below."; return; }
    pstat.textContent='Reading label…';
    Tesseract.recognize(file,'eng',{logger:function(m){ if(m.status==='recognizing text'){ pf.style.width=Math.round(m.progress*100)+'%'; }}})
    .then(function(res){
      var data=res.data;
      pf.style.width='100%';
      var found=detectInText(data.text||'');
      if(!found.length){ pstat.textContent="Couldn't match any known compounds — the label may be blurry or curved. Try again, or add manually below."; return; }
      pstat.textContent='Detected '+found.length+' compound'+(found.length>1?'s':'')+' — tap to add:';
      detectedEl.innerHTML=found.map(function(c){ return '<button class="dchip" data-id="'+c.id+'"><span class="plus">+</span>'+c.name+'</button>'; }).join('');
      Array.prototype.forEach.call(detectedEl.querySelectorAll('.dchip'),function(b){ b.addEventListener('click',function(){ add(b.dataset.id); b.remove(); if(!detectedEl.children.length) pstat.textContent='All detected compounds added. Verify doses below against the label.'; }); });
    })
    .catch(function(){ pstat.textContent="Something went wrong reading that image — add your ingredients manually below."; });
  });
  function detectInText(text){
    var t=(' '+text.toLowerCase().replace(/[^a-z0-9\s-]/g,' ')+' ').replace(/\s+/g,' ');
    var chosen={}; stack.forEach(function(s){ chosen[s.compound.id]=1; });
    var out=[];
    COMPOUNDS.forEach(function(c){
      if(chosen[c.id]||out.indexOf(c)>-1) return;
      if(c.aliases.some(function(a){ return t.indexOf(' '+a.trim()+' ')>-1||t.indexOf(a.trim())>-1; })) out.push(c);
    });
    return out;
  }

  /* Search + manual add */
  var searchEl=$id('search'), resultsEl=$id('results'); var activeIdx=-1;
  function matches(q){
    q=q.trim().toLowerCase(); if(!q) return [];
    var chosen={}; stack.forEach(function(s){ chosen[s.compound.id]=1; });
    return COMPOUNDS.filter(function(c){ return !chosen[c.id] && (c.name.toLowerCase().indexOf(q)>-1||c.aliases.some(function(a){ return a.indexOf(q)>-1; })); }).slice(0,7);
  }
  function renderResults(){
    var list=matches(searchEl.value);
    if(!list.length){ resultsEl.classList.add('hidden'); return; }
    resultsEl.innerHTML=list.map(function(c,i){ return '<button data-id="'+c.id+'" class="'+(i===activeIdx?'active':'')+'"><span class="r-name">'+c.name+'</span><span class="r-cat">'+c.cat+'</span></button>'; }).join('');
    resultsEl.classList.remove('hidden');
    Array.prototype.forEach.call(resultsEl.querySelectorAll('button'),function(b){ b.addEventListener('mousedown',function(e){ e.preventDefault(); add(b.dataset.id); }); });
  }
  searchEl.addEventListener('input',function(){ activeIdx=-1; renderResults(); });
  searchEl.addEventListener('keydown',function(e){
    var list=matches(searchEl.value);
    if(e.key==='ArrowDown'){ e.preventDefault(); activeIdx=Math.min(activeIdx+1,list.length-1); renderResults(); }
    else if(e.key==='ArrowUp'){ e.preventDefault(); activeIdx=Math.max(activeIdx-1,0); renderResults(); }
    else if(e.key==='Enter'){ e.preventDefault(); if(list[activeIdx]) add(list[activeIdx].id); else if(list[0]) add(list[0].id); }
    else if(e.key==='Escape'){ resultsEl.classList.add('hidden'); }
  });
  searchEl.addEventListener('blur',function(){ setTimeout(function(){ resultsEl.classList.add('hidden'); },120); });

  function add(id){
    var c=COMPOUNDS.find(function(x){ return x.id===id; });
    if(!c||stack.some(function(s){ return s.compound.id===id; })) return;
    stack.push({compound:c,dose:c.typ});
    searchEl.value=''; activeIdx=-1; resultsEl.classList.add('hidden'); renderStack(); compute(); searchEl.focus();
  }
  function remove(id){ stack=stack.filter(function(s){ return s.compound.id!==id; }); renderStack(); compute(); }

  var addedEl=$id('added');
  function renderStack(){
    if(!stack.length){ addedEl.innerHTML='<div class="empty">Nothing added yet. Snap a label or start typing above.</div>'; return; }
    addedEl.innerHTML=stack.map(function(s){ return '<div class="row"><div class="r-main"><div class="r-title">'+s.compound.name+'</div><div class="r-sub">'+s.compound.cat+' · typical '+fmt(s.compound.typ)+s.compound.unit+'</div></div><div class="dose"><input type="number" min="0" step="any" value="'+s.dose+'" data-id="'+s.compound.id+'" aria-label="dose for '+s.compound.name+'" inputmode="decimal" /><span class="unit">'+s.compound.unit+'</span></div><button class="rm" data-id="'+s.compound.id+'" aria-label="Remove '+s.compound.name+'">×</button></div>'; }).join('');
    Array.prototype.forEach.call(addedEl.querySelectorAll('.dose input'),function(inp){ inp.addEventListener('input',function(){ var s=stack.find(function(x){ return x.compound.id===inp.dataset.id; }); s.dose=parseFloat(inp.value)||0; compute(); }); });
    Array.prototype.forEach.call(addedEl.querySelectorAll('.rm'),function(b){ b.addEventListener('click',function(){ remove(b.dataset.id); }); });
  }
  function fmt(n){ return (Math.round(n*100)/100).toString(); }

  /* Meters + flags + product suggestions */
  var metersEl=$id('meters'), flagsEl=$id('flags'), metersPanel=$id('meters-panel'), suggestPanel=$id('suggest-panel'), prodsEl=$id('prods');
  function meterHTML(name,value,caution,high,unit,hasAche){
    var pct=Math.min(100,(value/high)*100);
    var color='var(--green)',status='status-clear',word='Clear';
    if(value>=high){ color='var(--red)';status='status-high';word='High'; }
    else if(value>=caution){ color='var(--amber)';status='status-caution';word='Caution'; }
    var valLabel=unit==='units'?(fmt(value)+' units · '+word):(fmt(value)+unit+' · '+word);
    return '<div class="meter"><div class="m-top"><span class="m-name">'+name+(hasAche?' <span class="cycle">+ AChE</span>':'')+'</span><span class="m-val '+status+'">'+valLabel+'</span></div><div class="track"><div class="fill" style="width:'+pct+'%;background:'+color+'"></div></div><div class="ticks"><span>clear</span><span>caution '+fmt(caution)+(unit==='units'?'':unit)+'</span><span>high '+fmt(high)+(unit==='units'?'':unit)+'</span></div></div>';
  }
  function compute(){
    if(!stack.length){ metersPanel.classList.add('hidden'); suggestPanel.classList.add('hidden'); return; }
    metersPanel.classList.remove('hidden');
    var choline=0,hasAche=false,caffeine=0,stimCount=0;
    var serotonergic=[],bloodThin=[],sedating=[];
    stack.forEach(function(s){
      var c=s.compound,scale=c.typ?(s.dose/c.typ):0;
      if(c.cholineLoad){ choline+=c.cholineLoad*scale; if(c.ache) hasAche=true; }
      if(c.caffeinePerMg){ caffeine+=s.dose*c.caffeinePerMg; }
      if(c.stimulant) stimCount++;
      if(c.serotonergic) serotonergic.push(c.name);
      if(c.bloodThinning) bloodThin.push(c.name);
      if(c.sedating) sedating.push(c.name);
    });
    if(hasAche) choline*=1.4;
    metersEl.innerHTML=meterHTML('Cholinergic load',choline,4,6,'units',hasAche)+meterHTML('Caffeine',caffeine,200,400,'mg',false)+meterHTML('Stimulant sources',stimCount,2,3,'',false);

    var flags=[];
    if(choline>=6) flags.push(['danger','!','<b>High combined cholinergic load.</b> Stacking choline donors'+(hasAche?' with an acetylcholinesterase inhibitor ':' ')+'is the most common cause of nootropic headaches, brain fog, and nausea. Consider reducing one donor or spacing them out.']);
    else if(choline>=4) flags.push(['warn','~','<b>Moderate cholinergic load.</b> You have overlapping choline sources. Watch for a dull headache or queasiness; lowering one dose usually resolves it.']);
    if(hasAche) flags.push(['warn','~','<b>Huperzine A lingers 24h+.</b> Its effect carries into the next day and compounds if you dose choline daily — most bottles suggest cycling with days off.']);
    if(caffeine>=400) flags.push(['danger','!','<b>'+Math.round(caffeine)+'mg caffeine</b> — above the ~400mg/day general ceiling for healthy adults. Expect jitters, raised heart rate, disrupted sleep.']);
    else if(caffeine>=200) flags.push(['warn','~','<b>'+Math.round(caffeine)+'mg caffeine</b> across your sources — roughly two-plus cups of coffee. Fine for most, but dose it before early afternoon.']);
    if(stimCount>=3) flags.push(['warn','~','<b>Three or more stimulant sources.</b> These stack additively even when each is modest. Consider trimming to one primary stimulant.']);
    if(serotonergic.length) flags.push(['warn','~','<b>Interaction note:</b> '+serotonergic.join(', ')+' can act on serotonin pathways — caution with SSRIs, SNRIs, or MAOIs.']);
    if(bloodThin.length) flags.push(['warn','~','<b>Interaction note:</b> '+bloodThin.join(', ')+' can affect blood clotting — caution with anticoagulants and before surgery.']);
    if(sedating.length>=3) flags.push(['warn','~','<b>Several calming compounds</b> ('+sedating.join(', ')+'). Combined, they may leave you drowsy rather than sharp.']);
    if(!flags.length) flags.push(['ok','✓','No overlap or threshold issues detected in this combination. Loads are within common ranges.']);
    flagsEl.innerHTML=flags.map(function(f){ return '<div class="flag '+f[0]+'"><span class="ico">'+f[1]+'</span><span>'+f[2]+'</span></div>'; }).join('');

    renderSuggestions(stack);
  }

  function renderSuggestions(stk){
    var has=function(id){ return stk.some(function(s){ return s.compound.id===id; }); };
    var hasTag=function(fn){ return stk.some(function(s){ return fn(s.compound); }); };
    var recs=[]; var used={};
    function addRec(tag,why){ var p=findProduct(tag); if(p&&!used[p.handle]){ used[p.handle]=1; recs.push({p:p,why:why||p.why}); } }
    if(hasTag(function(c){ return c.stimulant; })) addRec('hydration');
    if(hasTag(function(c){ return c.cholineLoad; }) && !has('bacopa') && !has('lionsmane')) addRec('memory','You have choline on board — pairing it with bacopa/ginkgo supports the long-game memory side.');
    if(hasTag(function(c){ return c.stimulant; }) && !hasTag(function(c){ return c.cat==='Adaptogen'; })) addRec('focus','Adding an adaptogen can smooth the stimulant edge and steady energy.');
    if(!has('dha')) addRec('longterm','No omega-3 in your stack — DHA is the structural foundation most brain formulas build on.');
    if(!recs.length) addRec('general');
    suggestPanel.classList.remove('hidden');
    prodsEl.innerHTML=recs.slice(0,3).map(function(r){ return '<div class="prod"><div class="p-body"><div class="p-name">'+r.p.name+'</div><div class="p-why">'+r.why+'</div></div><a class="shop" href="'+productUrl(r.p.handle)+'" target="_blank" rel="noopener">Shop</a></div>'; }).join('');
  }

  /* Tabs */
  var tabCheck=$id('tab-check'),tabBuild=$id('tab-build'),viewCheck=$id('view-check'),viewBuild=$id('view-build');
  function selectTab(which){
    var check=which==='check';
    tabCheck.setAttribute('aria-selected',check); tabBuild.setAttribute('aria-selected',!check);
    viewCheck.classList.toggle('hidden',!check); viewBuild.classList.toggle('hidden',check);
  }
  tabCheck.addEventListener('click',function(){ selectTab('check'); });
  tabBuild.addEventListener('click',function(){ selectTab('build'); });

  /* Regimen builder */
  var GOALS=[{id:'focus',label:'Focus & attention'},{id:'memory',label:'Memory & learning'},{id:'stress',label:'Stress & mood'},{id:'energy',label:'Sustained energy'},{id:'longterm',label:'Long-term brain health'}];
  var CONSTRAINTS=[{id:'nostim',label:'No stimulants'},{id:'nolong',label:'Same-day effects only'}];
  var goalState={},consState={};
  function renderChips(el,arr,state){
    el.innerHTML=arr.map(function(o){ return '<button class="chip" aria-pressed="false" data-id="'+o.id+'">'+o.label+'</button>'; }).join('');
    Array.prototype.forEach.call(el.querySelectorAll('.chip'),function(b){ b.addEventListener('click',function(){ var id=b.dataset.id; if(state[id]){ delete state[id]; b.setAttribute('aria-pressed','false'); } else { state[id]=1; b.setAttribute('aria-pressed','true'); } }); });
  }
  renderChips($id('goals'),GOALS,goalState);
  renderChips($id('constraints'),CONSTRAINTS,consState);

  var regimenPanel=$id('regimen-panel'),schedEl=$id('sched'),regimenFlagsEl=$id('regimen-flags'),regimenSuggestPanel=$id('regimen-suggest-panel'),regimenProdsEl=$id('regimen-prods');

  function generate(){
    var noStim=!!consState['nostim'],noLong=!!consState['nolong'];
    var want=function(id){ return !!goalState[id]; };
    var picks=[];
    if(want('focus')||want('energy')){ if(noStim){ push(picks,'rhodiola',300); } else { push(picks,'caffeine',100); push(picks,'ltheanine',200); } }
    if(want('focus')&&!noStim) push(picks,'ltheanine',200);
    if(want('focus')||want('memory')) push(picks,'citicoline',300);
    if(want('memory')){ if(!noLong){ push(picks,'bacopa',300); push(picks,'lionsmane',1000); } push(picks,'nalt',350); }
    if(want('stress')){ push(picks,'nalt',350); if(!noLong) push(picks,'ashwagandha',500); push(picks,'ltheanine',200); }
    if(want('energy')){ push(picks,'alcar',500); push(picks,'creatine',5); if(!noStim) push(picks,'rhodiola',300); }
    if(want('longterm')){ push(picks,'dha',700); push(picks,'creatine',5); if(!noLong){ push(picks,'lionsmane',1000); push(picks,'pqq',15); push(picks,'magthreonate',1500); } }
    if(noLong) picks=picks.filter(function(p){ return p.compound.onset==='same-day'; });
    if(noStim) picks=picks.filter(function(p){ return !p.compound.stimulant; });

    if(!picks.length){ regimenPanel.classList.remove('hidden'); schedEl.innerHTML='<div class="empty">Pick at least one goal to generate a regimen.</div>'; regimenFlagsEl.innerHTML=''; regimenSuggestPanel.classList.add('hidden'); return; }

    var am=picks.filter(function(p){ return p.compound.timing!=='PM'&&p.compound.onset==='same-day'; });
    var pm=picks.filter(function(p){ return p.compound.timing==='PM'&&p.compound.onset==='same-day'; });
    var longGame=picks.filter(function(p){ return p.compound.onset==='long-game'; });
    var html='';
    if(am.length) html+=block('Morning','Same-day · with or before breakfast',am);
    if(pm.length) html+=block('Evening','Same-day · with dinner',pm);
    if(longGame.length) html+=block('Builds over weeks','Consistency matters more than timing',longGame);
    schedEl.innerHTML=html;
    regimenFlagsEl.innerHTML=checkGenerated(picks).map(function(f){ return '<div class="flag '+f[0]+'"><span class="ico">'+f[1]+'</span><span>'+f[2]+'</span></div>'; }).join('');
    regimenPanel.classList.remove('hidden');
    renderSuggestionsTo(picks,regimenProdsEl,regimenSuggestPanel);
    regimenPanel.scrollIntoView({behavior:'smooth',block:'nearest'});
  }
  function renderSuggestionsTo(picks,el,panel){
    var stk=picks.map(function(p){ return {compound:p.compound}; });
    var has=function(id){ return stk.some(function(s){ return s.compound.id===id; }); };
    var hasTag=function(fn){ return stk.some(function(s){ return fn(s.compound); }); };
    var recs=[]; var used={};
    function addRec(tag,why){ var p=findProduct(tag); if(p&&!used[p.handle]){ used[p.handle]=1; recs.push({p:p,why:why||p.why}); } }
    if(hasTag(function(c){ return c.stimulant; })) addRec('hydration');
    if(hasTag(function(c){ return c.cholineLoad; })) addRec('focus','A pre-formulated focus blend can cover your same-day base in one product.');
    if(has('bacopa')||has('lionsmane')) addRec('memory');
    if(!recs.length) addRec('general');
    panel.classList.remove('hidden');
    el.innerHTML=recs.slice(0,3).map(function(r){ return '<div class="prod"><div class="p-body"><div class="p-name">'+r.p.name+'</div><div class="p-why">'+r.why+'</div></div><a class="shop" href="'+productUrl(r.p.handle)+'" target="_blank" rel="noopener">Shop</a></div>'; }).join('');
  }
  function push(arr,id,dose){
    var c=COMPOUNDS.find(function(x){ return x.id===id; }); if(!c) return;
    if(c.cholineLoad&&!c.ache&&arr.some(function(p){ return p.compound.cholineLoad&&!p.compound.ache; })) return;
    if(arr.some(function(p){ return p.compound.id===id; })) return;
    arr.push({compound:c,dose:dose});
  }
  function block(label,tag,items){
    return '<div class="block"><div class="block-h"><span class="lbl">'+label+'</span><span class="tag">'+tag+'</span></div>'+items.map(function(p){ return '<div class="item"><div class="idose">'+fmt(p.dose)+p.compound.unit+'</div><div><div class="iname">'+p.compound.name+(p.compound.cycle==='cycle'?'<span class="cycle">cycle 5-on/2-off</span>':'')+'</div><div class="inote">'+p.compound.note+'</div></div></div>'; }).join('')+'</div>';
  }
  function checkGenerated(picks){
    var choline=0,hasAche=false,caffeine=0;
    picks.forEach(function(p){ var c=p.compound,scale=c.typ?p.dose/c.typ:0; if(c.cholineLoad){choline+=c.cholineLoad*scale; if(c.ache)hasAche=true;} if(c.caffeinePerMg) caffeine+=p.dose*c.caffeinePerMg; });
    if(hasAche) choline*=1.4;
    return [
      ['ok','✓','This regimen keeps cholinergic load to '+fmt(choline)+' units and caffeine to '+Math.round(caffeine)+'mg — deliberately within clear ranges by using a single choline donor.'],
      ['warn','~','<b>Start low and add one at a time.</b> Introduce a single new compound and give it 1–2 weeks before adding the next, so you can attribute effects and catch anything that doesn\'t sit well.']
    ];
  }
  $id('generate').addEventListener('click',generate);

  renderStack();
})();
</script>

