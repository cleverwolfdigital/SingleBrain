# Copy to `.env` on the VPS and fill in real values.
# systemd loads this via `EnvironmentFile=-/root/singlebrain-app/.env`.
# NEVER commit the real .env — it is gitignored.

# --- Auth (Magic Link + TOTP 2FA) ---
SB_SECRET_KEY=change-me-to-a-long-random-string
SB_ALLOWED_DOMAIN=cleverwolfdigital.com
SB_BASE_URL=https://brain.cleverwolfdigital.com

# --- Access control ---
# Comma-separated emails that are always Super Admins (see everything + admin panel).
SB_SUPER_ADMINS=quincy@cleverwolfdigital.com
# Where feedback (bug/suggestion) emails are sent. Defaults to the first super admin.
SB_FEEDBACK_TO=

# --- Email for magic links (Resend via SMTP) ---
# For Resend: host=smtp.resend.com, user=resend, pass=<your re_… API key>
SB_SMTP_HOST=
SB_SMTP_PORT=587
SB_SMTP_USER=
SB_SMTP_PASS=
SB_MAIL_FROM=Single Brain <noreply@cleverwolfdigital.com>

# --- CWD Brain Chat (Grok / xAI) ---
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4

# --- Data + source-of-truth repo ---
SB_DATA_DIR=/root/singlebrain-app/data
SB_BRAIN_REPO=/root/singlebrain
SB_GIT_PUSH=1

# --- Google Drive + Calendar integration (OAuth 2.0) ---
# Calendar is read-only; Drive uses the full `drive` scope so the dashboard can
# upload and share files. Users who connected before this change must reconnect
# once to re-consent to the wider Drive permission.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://brain.cleverwolfdigital.com/auth/google/callback
# Max Drive upload size in MB per file (single-request multipart upload). Default 25.
SB_MAX_UPLOAD_MB=25
